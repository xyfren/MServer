{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cd ${workspaceFolder} && mkdir -p build && cd build && cmake .. && make -j$(nproc)",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "cmake: build and run",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && cmake .. && make -j$(nproc) && ./MServer",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "cmake: fast build",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && make -j$(nproc)",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}